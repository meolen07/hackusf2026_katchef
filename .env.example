# -----------------------------
# Backend app
# -----------------------------
APP_NAME=KatChef API
APP_ENV=development
HOST=0.0.0.0
PORT=8081
LOG_LEVEL=info
BACKEND_CORS_ORIGINS=["http://localhost:19006","http://localhost:8081","http://localhost:8082"]
BACKEND_CORS_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$|^https://.*githubpreview\\.dev$|^https://.*app\\.github\\.dev$|^https://.*gitpod\\.io$|^https://.*exp\\.direct$
MAX_UPLOAD_SIZE_MB=8
ALLOWED_UPLOAD_CONTENT_TYPES=["image/jpeg","image/png","image/webp","image/heic","image/heif"]

# -----------------------------
# Backend: Firebase Admin / Vision
# Pick one credential style:
# 1. GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# 2. FIREBASE_SERVICE_ACCOUNT_JSON={...one-line-json...}
# -----------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=

# -----------------------------
# Backend: Gemini
# -----------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=20
CHATBOT_MAX_HISTORY=4

# -----------------------------
# Frontend: API
# EXPO_PUBLIC_API_BASE_URL wins when set.
# EXPO_PUBLIC_API_PORT is the dev fallback for Expo web / native when the host should match the current browser or Metro host.
# -----------------------------
EXPO_PUBLIC_API_BASE_URL=http://localhost:8081
EXPO_PUBLIC_API_PORT=8081

# -----------------------------
# Frontend: Firebase Web config
# Get these from Firebase Console > Project settings > Your apps > Web app
# -----------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
EXPO_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------
# Frontend: Google sign-in for web
# Get this from Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# -----------------------------
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# -----------------------------
# Optional: native Google client IDs for future mobile auth expansion
# Native Google sign-in uses the web client ID plus the iOS client ID.
# If you have Firebase GoogleService files, you can also provide them as shell env vars:
# GOOGLE_SERVICES_IOS_FILE=./GoogleService-Info.plist
# GOOGLE_SERVICES_ANDROID_FILE=./google-services.json
# -----------------------------
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
